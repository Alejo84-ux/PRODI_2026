// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
function showToast(msg){
  var t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(function(){t.classList.remove('show')},2800);
}
function ini(name){
  return name.split(' ').map(function(w){return w[0]||''}).join('').substring(0,2).toUpperCase();
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  RENDER PARTIDOS
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
function matchCard(m){
  var saved = currentUser && pronosticos[currentUser] && pronosticos[currentUser][m.id];
  var hv = saved ? saved.h : '';
  var av = saved ? saved.a : '';
  var lbl = m.label ? '<div style="font-size:11px;color:var(--gold);margin-bottom:4px;font-weight:600">'+m.label+'</div>' : '';
  return '<div class="match-card'+(saved?' saved':'')+'" id="mc-'+m.id+'">'+lbl+
    '<div class="match-top">'+
      '<div class="team-block right"><span class="team-name">'+m.local+'</span></div>'+
      '<div class="score-inputs">'+
        '<input type="number" min="0" max="20" class="score-in" id="h-'+m.id+'" value="'+hv+'" onchange="markChanged(\''+m.id+'\')" placeholder="-">'+
        '<span class="vs-sep">VS</span>'+
        '<input type="number" min="0" max="20" class="score-in" id="a-'+m.id+'" value="'+av+'" onchange="markChanged(\''+m.id+'\')" placeholder="-">'+
      '</div>'+
      '<div class="team-block"><span class="team-name">'+m.visita+'</span></div>'+
    '</div>'+
    '<div class="match-meta"><span>рџ“… '+m.fecha+' В· '+m.hora+'</span><span>рџ“Ќ '+m.sede+'</span></div>'+
  '</div>';
}

function renderMatches(phase){
  var container=document.getElementById('matches-container');
  if(phase==='extras'){renderExtras(container);return;}
  var matches=FIXTURE[phase]; if(!matches)return;
  if(phase==='grupos'){
    var groups={};
    matches.forEach(function(m){if(!groups[m.grupo])groups[m.grupo]=[];groups[m.grupo].push(m);});
    container.innerHTML=Object.keys(groups).map(function(g){
      return '<div class="grupo-block"><div class="grupo-label">Grupo '+g+'</div>'+groups[g].map(matchCard).join('')+'</div>';
    }).join('');
  } else {
    container.innerHTML=matches.map(matchCard).join('');
  }
  loadInputValues();
}

function renderExtras(container){
  // Construir HTML de autores de gol argentino agrupado por partido
  var argByPartido={};
  ARG_PARTIDOS.forEach(function(p){ argByPartido[p.key]=[]; });
  EXTRAS_DATA.arg.forEach(function(e){ if(argByPartido[e.partido]) argByPartido[e.partido].push(e); });

  var argSections='';
  ARG_PARTIDOS.forEach(function(p){
    var isFinal=(p.key==='F');
    var color=isFinal?'var(--gold)':'#75AADB';
    var icon=isFinal?'&#11088; ':'&#127462;&#127479; ';
    var nota=isFinal?'(Art.20 &mdash; +5pts c/u)':'(Art.13 &mdash; +1pt c/u)';
    var golesRows='';
    var lista=argByPartido[p.key]||[];
    for(var gi=0;gi<lista.length;gi++){
      var e=lista[gi];
      var n=e.id.split('_').pop();
      var pts=isFinal?'+5pts':'+1pt';
      var ptsColor=isFinal?'var(--gold)':'var(--text3)';
      golesRows+='<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">'
        +'<span style="font-size:11px;color:var(--text3);min-width:36px">Gol '+n+'</span>'
        +'<input type="text" class="arg-in" style="flex:1" id="'+e.id+'" list="dl-arg-squad" placeholder="EscribГ­ o elegГ­ jugador...">'
        +'<span style="font-size:10px;color:'+ptsColor+';background:rgba(128,128,128,.1);padding:2px 6px;border-radius:10px">'+pts+'</span>'
        +'</div>';
    }
    argSections+='<div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:10px">'
      +'<div style="font-size:12px;font-weight:600;color:'+color+';margin-bottom:8px">'+icon+p.label
      +' <span style="font-size:10px;font-weight:400;color:var(--text3)">'+nota+'</span></div>'
      +golesRows
      +'</div>';
  });

  var gridHtml='';
  for(var gi2=0;gi2<EXTRAS_DATA.grid.length;gi2++){
    var eg=EXTRAS_DATA.grid[gi2];
    var tp=eg.type||'text';
    gridHtml+='<div class="extra-block" id="eb-'+eg.id+'">'
      +'<label class="extra-label">'+eg.label+'</label>'
      +'<input type="'+tp+'" class="extra-in" id="'+eg.id+'" placeholder="...">'
      +'</div>';
  }

  container.innerHTML='<div class="extras-layout">'
    +'<div class="extras-col" style="min-width:280px">'
      +'<h3 style="font-family:Bebas Neue,sans-serif;font-size:22px;color:var(--text);margin-bottom:6px">&#127462;&#127479; Autores Gol <span style="color:#75AADB">Argentina</span></h3>'
      +'<p style="font-size:11px;color:var(--text3);margin-bottom:12px">Hasta '+MAX_GOLES_ARG+' goles por partido. Dej&aacute; vac&iacute;os los que no se usen.</p>'
      +argSections
    +'</div>'
    +'<div class="extras-col">'
      +'<h3 style="font-family:Bebas Neue,sans-serif;font-size:22px;color:var(--gold);margin-bottom:14px">&#127919; Predicciones Generales</h3>'
      +'<div class="extras-grid">'+gridHtml+'</div>'
    +'</div>'
  +'</div>';

  // Agregar onchange via JS para evitar problemas de comillas anidadas
  EXTRAS_DATA.arg.forEach(function(e){
    var el=document.getElementById(e.id);
    if(el) el.onchange=function(){ markExtraChanged(e.id); };
  });
  EXTRAS_DATA.grid.forEach(function(e){
    var el=document.getElementById(e.id);
    if(el) el.onchange=function(){ markExtraChanged(e.id); };
  });

  loadInputValues();
}

function loadInputValues(){
  if(!currentUser)return;
  var ups=pronosticos[currentUser]||{};
  if(currentPhase==='extras'){
    var ext=ups.extras||{};
    EXTRAS_DATA.arg.concat(EXTRAS_DATA.grid).forEach(function(e){
      var el=document.getElementById(e.id);
      if(el&&ext[e.id]!==undefined)el.value=ext[e.id];
    });
    return;
  }
  Object.keys(ups).forEach(function(id){
    if(id==='extras')return;
    var hi=document.getElementById('h-'+id);
    var ai=document.getElementById('a-'+id);
    if(hi)hi.value=ups[id].h;
    if(ai)ai.value=ups[id].a;
  });
}

function markChanged(id){
  var c=document.getElementById('mc-'+id);
  if(c)c.style.borderColor='rgba(201,162,39,.4)';
}
function markExtraChanged(id){
  var b=document.getElementById('eb-'+id);
  if(b)b.style.borderColor='rgba(201,162,39,.4)';
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  SAVE PRONГ“STICOS
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
function savePronosticos(){
  if(!currentUser){showToast('вљ пёЏ Primero ingresГЎ al grupo');return;}
  // Bloqueo solo para Fase de Grupos y Extras
  var fasesBlockeadas = ['grupos','extras'];
  if(pronosticosBloqueados && currentUser!=='ORGANIZADOR' && fasesBlockeadas.indexOf(currentPhase)>=0){
    showToast('рџ”’ Grupos y Extras cerrados. PodГ©s cargar fases eliminatorias.');
    return;
  }
  if(!pronosticos[currentUser])pronosticos[currentUser]={};
  var count=0;

  if(currentPhase==='extras'){
    if(!pronosticos[currentUser].extras)pronosticos[currentUser].extras={};
    EXTRAS_DATA.arg.concat(EXTRAS_DATA.grid).forEach(function(e){
      var el=document.getElementById(e.id);
      if(el&&el.value.trim()!==''){
        pronosticos[currentUser].extras[e.id]=e.type==='number'?parseInt(el.value):el.value.trim();
        count++;
      }
    });
  } else {
    Object.keys(FIXTURE).forEach(function(phase){
      FIXTURE[phase].forEach(function(m){
        var hi=document.getElementById('h-'+m.id);
        var ai=document.getElementById('a-'+m.id);
        if(hi&&ai&&hi.value!==''&&ai.value!==''){
          pronosticos[currentUser][m.id]={h:parseInt(hi.value),a:parseInt(ai.value)};
          var card=document.getElementById('mc-'+m.id);
          if(card){card.classList.add('saved');card.style.borderColor='';}
          count++;
        }
      });
    });
  }

  localStorage.setItem('prodeData_'+currentUser,JSON.stringify(pronosticos[currentUser]));
  db.collection('pronosticos').doc(currentUser).set({
    nombre:currentUser,
    pronosticos:pronosticos[currentUser],
    updatedAt:new Date().toISOString()
  }).then(function(){
    showToast('вњ… '+count+' datos guardados');
  }).catch(function(err){
    showToast('вљ пёЏ Guardado local OK вЂ” Firebase: '+err.message);
  });
  updateStats(); updateTabla(); updateMatchSelector();
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  PANEL ORGANIZADOR
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
function renderAdminPanel(){
  var card=document.getElementById('resultados-card');
  if(!card||currentUser!=='ORGANIZADOR')return;
  var html='<div style="padding:20px">';
  html+='<h3 style="color:var(--gold);margin-bottom:15px;font-family:Bebas Neue,sans-serif;font-size:24px;text-align:center">PANEL DE CONTROL</h3>';

  // в”Ђв”Ђ BLOQUEO DE PRONГ“STICOS в”Ђв”Ђ
  var isLocked = pronosticosBloqueados;
  var lockBg    = isLocked ? 'rgba(239,68,68,.12)'        : 'rgba(45,158,92,.08)';
  var lockBord  = isLocked ? 'rgba(239,68,68,.35)'        : 'rgba(45,158,92,.3)';
  var lockColor = isLocked ? '#f87171'                    : '#4ade80';
  var lockIcon  = isLocked ? 'рџ”’'                         : 'рџ”“';
  var lockLabel = isLocked ? 'PRONГ“STICOS CERRADOS'       : 'PRONГ“STICOS ABIERTOS';
  var lockDesc  = isLocked ? 'Grupos y Extras bloqueados. Las fases eliminatorias siguen abiertas.'
                           : 'Los jugadores pueden cargar Grupos y Extras normalmente.';
  var lockBtnTxt= isLocked ? 'рџ”“ ABRIR GRUPOS Y EXTRAS'    : 'рџ”’ CERRAR GRUPOS Y EXTRAS';
  var lockBtnBg = isLocked ? 'var(--green-mid)'           : '#dc2626';
  html += '<div style="background:'+lockBg+';border:2px solid '+lockBord+';border-radius:var(--radius-lg);padding:18px 20px;margin-bottom:24px;">'
    +'<div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;">'
      +'<div style="font-size:36px">'+lockIcon+'</div>'
      +'<div style="flex:1;">'
        +'<div style="font-family:Bebas Neue,sans-serif;font-size:20px;letter-spacing:1px;color:'+lockColor+'">'+lockLabel+'</div>'
        +'<div style="font-size:12px;color:var(--text2);margin-top:3px">'+lockDesc+'</div>'
      +'</div>'
      +'<button onclick="toggleLock()" style="padding:12px 20px;background:'+lockBtnBg+';color:#fff;border:none;border-radius:var(--radius);font-family:Bebas Neue,sans-serif;font-size:16px;letter-spacing:1px;cursor:pointer;white-space:nowrap">'+lockBtnTxt+'</button>'
    +'</div>'
  +'</div>';
  
  Object.keys(FIXTURE).forEach(function(phase){
    html+='<div style="margin:20px 0 10px;font-size:14px;font-weight:bold;color:var(--text2);text-transform:uppercase;border-bottom:1px solid var(--border);padding-bottom:4px">'+phase+'</div>';
    FIXTURE[phase].forEach(function(m){
      var r=RESULTADOS_OFICIALES[m.id]||{h:'',a:''};
      html+='<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;background:var(--bg3);padding:8px;border-radius:8px">'+
        '<span style="flex:1;text-align:right;font-size:12px;font-weight:500">'+m.local+'</span>'+
        '<input type="number" min="0" max="20" id="of-h-'+m.id+'" value="'+r.h+'" style="width:36px;text-align:center;background:var(--bg);color:white;border:1px solid var(--border);border-radius:4px;padding:4px;font-family:Bebas Neue,sans-serif;font-size:16px;outline:none">'+
        '<span style="color:var(--text3);font-size:11px">VS</span>'+
        '<input type="number" min="0" max="20" id="of-a-'+m.id+'" value="'+r.a+'" style="width:36px;text-align:center;background:var(--bg);color:white;border:1px solid var(--border);border-radius:4px;padding:4px;font-family:Bebas Neue,sans-serif;font-size:16px;outline:none">'+
        '<span style="flex:1;font-size:12px;font-weight:500">'+m.visita+'</span>'+
      '</div>';
    });
  });
  html+='<div style="margin:30px 0 10px;font-size:16px;font-weight:bold;color:var(--gold);border-bottom:1px solid var(--gold);padding-bottom:4px">EXTRAS</div>';
  // Autores de gol argentino con datalist
  EXTRAS_DATA.arg.forEach(function(e){
    var val=RESULTADOS_OFICIALES.extras[e.id]||'';
    var isFinal=(e.partido==='F');
    var pts=isFinal?'+5pts':'+1pt';
    html+='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;background:var(--bg3);padding:8px 12px;border-radius:8px">'+
      '<span style="font-size:12px;color:'+(isFinal?'var(--gold)':'#75AADB')+';font-weight:500">'+e.label+' <span style="font-size:10px;color:var(--text3)">'+pts+'</span></span>'+
      '<input type="text" id="of-ext-'+e.id+'" value="'+val+'" list="dl-arg-squad" placeholder="ElegГ­ jugador..." style="width:180px;background:var(--bg);color:white;border:1px solid var(--border);border-radius:4px;padding:6px;font-family:Inter,sans-serif;font-size:12px;outline:none">'+
    '</div>';
  });
  // Predicciones generales (sin datalist)
  EXTRAS_DATA.grid.forEach(function(e){
    var val=RESULTADOS_OFICIALES.extras[e.id]||'';
    html+='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;background:var(--bg3);padding:8px 12px;border-radius:8px">'+
      '<span style="font-size:12px;color:var(--text);font-weight:500">'+e.label+'</span>'+
      '<input type="text" id="of-ext-'+e.id+'" value="'+val+'" placeholder="..." style="width:140px;background:var(--bg);color:white;border:1px solid var(--border);border-radius:4px;padding:6px;font-family:Inter,sans-serif;font-size:12px;outline:none">'+
    '</div>';
  });
  // SecciГіn: partidos de Argentina en fase eliminatoria
  html+='<div style="margin:30px 0 10px;font-size:16px;font-weight:bold;color:#75AADB;border-bottom:1px solid rgba(117,170,219,.3);padding-bottom:4px">рџ‡¦рџ‡· PARTIDOS ARGENTINA вЂ” FASE ELIMINATORIA</div>';
  html+='<p style="font-size:12px;color:var(--text3);margin-bottom:12px">MarcГЎ en quГ© partidos jugГі Argentina (para calcular bonus/penalidades Arts. 18-20)</p>';
  var argPartidos = RESULTADOS_OFICIALES.argPartidos || [];
  var elimPhases = ['r32','r16','cuartos','semis','final'];
  elimPhases.forEach(function(ph){
    if(!FIXTURE[ph])return;
    FIXTURE[ph].forEach(function(m){
      var checked = argPartidos.indexOf(m.id)>=0 ? 'checked' : '';
      var is3rd = m.id==='3RD';
      html+='<label style="display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--bg3);border-radius:8px;margin-bottom:6px;cursor:pointer;border:1px solid var(--border);">'+
        '<input type="checkbox" id="argp-'+m.id+'" '+checked+' style="width:16px;height:16px;accent-color:#75AADB">'+
        '<span style="font-size:12px;flex:1">'+m.local+' vs '+m.visita+' <span style="color:var(--text3)">('+m.fecha+')</span></span>'+
        (is3rd?'<span style="font-size:10px;color:#f87171;background:rgba(248,113,113,.1);padding:2px 6px;border-radius:10px">вљ пёЏ Si marcГЎs esto: в€’5pts a quienes pronostiquen Argentina aquГ­</span>':'')+
      '</label>';
    });
  });

  // SecciГіn: bonus cierre de grupos Arts. 14 & 15
  html+='<div style="margin:30px 0 10px;font-size:16px;font-weight:bold;color:var(--gold);border-bottom:1px solid var(--gold);padding-bottom:4px">вљЎ CLГЃUSULAS CIERRE DE GRUPOS (Arts. 14 & 15)</div>';
  var bonusCierre = RESULTADOS_OFICIALES.bonusCierre || {};
  var allUsers = Object.keys(pronosticos);

  if(!allUsers.length){
    html+='<p style="font-size:12px;color:var(--text3);padding:12px">AГєn no hay participantes registrados.</p>';
  } else {
    // Calcular posiciones actuales para mostrar quiГ©n estГЎ 1В° y Гєltimo
    var tempRows = allUsers.map(function(u){ return {u:u, pts:calcPuntos(u).pts}; });
    tempRows.sort(function(a,b){return b.pts-a.pts;});
    var leader = tempRows[0].u;
    var last   = tempRows[tempRows.length-1].u;

    html+='<div style="background:var(--bg3);border-radius:8px;padding:14px;margin-bottom:10px;">';
    html+='<p style="font-size:12px;color:var(--text2);margin-bottom:12px">PosiciГіn actual al cerrar grupos. El botГіn aplica +5 al Гєltimo y в€’5 al primero <strong style="color:var(--gold)">una sola vez</strong>.</p>';
    html+='<div style="display:flex;gap:12px;margin-bottom:14px;flex-wrap:wrap;">';
    html+='<div style="flex:1;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);border-radius:8px;padding:12px;min-width:160px">';
    html+='<div style="font-size:11px;color:#f87171;font-weight:600;margin-bottom:4px">вљ пёЏ Art. 15 вЂ” LГ­der (в€’5 pts)</div>';
    html+='<div style="font-size:16px;font-weight:600;color:var(--text)">'+leader+'</div>';
    html+='<div style="font-size:12px;color:var(--text3)">'+tempRows[0].pts+' pts actuales</div></div>';
    html+='<div style="flex:1;background:rgba(74,222,128,.08);border:1px solid rgba(74,222,128,.2);border-radius:8px;padding:12px;min-width:160px">';
    html+='<div style="font-size:11px;color:#4ade80;font-weight:600;margin-bottom:4px">рџЏ… Art. 14 вЂ” Гљltimo (+5 pts)</div>';
    html+='<div style="font-size:16px;font-weight:600;color:var(--text)">'+last+'</div>';
    html+='<div style="font-size:12px;color:var(--text3)">'+tempRows[tempRows.length-1].pts+' pts actuales</div></div>';
    html+='</div>';

    var yaaplicado = (bonusCierre[leader]!=null || bonusCierre[last]!=null);
    if(yaaplicado){
      html+='<div style="padding:10px 14px;background:rgba(45,158,92,.1);border:1px solid rgba(45,158,92,.3);border-radius:8px;font-size:12px;color:#4ade80">вњ… ClГЎusulas ya aplicadas. Para revertir, publicГЎ resultados nuevamente con el botГіn principal.</div>';
    } else {
      html+='<button onclick="aplicarCierre('+JSON.stringify(leader)+','+JSON.stringify(last)+')" style="width:100%;padding:12px;background:rgba(201,162,39,.15);border:1px solid var(--gold);border-radius:8px;font-size:18px;letter-spacing:1px;cursor:pointer;color:var(--gold)">&#9889; APLICAR CL&#193;USULAS DE CIERRE</button>';
    }
    html+='</div>';
  }

  var btnStyle='width:100%;padding:14px;margin-top:24px;background:var(--gold);color:#000;border:none;border-radius:8px;font-family:Bebas Neue,sans-serif;font-size:20px;letter-spacing:1px;cursor:pointer';
  html+='<button onclick="saveOficiales()" style="'+btnStyle+'">&#128190; PUBLICAR RESULTADOS</button>';
  html+='</div>';
  card.innerHTML=html;
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
// BLOQUEO DE PRONГ“STICOS
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
function toggleLock(){
  var newState = !pronosticosBloqueados;
  var msg = newState
    ? 'ВїCerrar Grupos y Extras? Las fases eliminatorias quedan abiertas.'
    : 'ВїAbrir Grupos y Extras? Los jugadores podrГЎn volver a cargar.';
  if(!confirm(msg)) return;

  // Guardar en Firebase bajo ORGANIZADOR
  // Usar update() para modificar SOLO el campo pronosticosBloqueados
  // sin tocar los resultados, bonusCierre ni ningГєn otro dato
  if(db){
    db.collection('pronosticos').doc('ORGANIZADOR').update({
      'pronosticos.pronosticosBloqueados': newState,
      updatedAt: new Date().toISOString()
    }).then(function(){
      pronosticosBloqueados = newState;
      updateLockBanner();
      renderAdminPanel();
      updateLockBadgeInicio();
      showToast(newState ? 'рџ”’ Grupos y Extras cerrados' : 'рџ”“ Grupos y Extras abiertos');
    }).catch(function(err){
      // Si el doc no existe aГєn, crear con set
      var data = Object.assign({}, RESULTADOS_OFICIALES);
      data.pronosticosBloqueados = newState;
      db.collection('pronosticos').doc('ORGANIZADOR').set({
        nombre:'ORGANIZADOR', pronosticos:data, updatedAt:new Date().toISOString()
      }).then(function(){
        pronosticosBloqueados = newState;
        updateLockBanner(); renderAdminPanel(); updateLockBadgeInicio();
        showToast(newState ? 'рџ”’ Grupos y Extras cerrados' : 'рџ”“ Grupos y Extras abiertos');
      }).catch(function(e){ showToast('вќЊ Error: '+e.message); });
    });
  } else {
    pronosticosBloqueados = newState;
    updateLockBanner();
    renderAdminPanel();
    updateLockBadgeInicio();
    showToast(newState ? 'рџ”’ Grupos y Extras cerrados (local)' : 'рџ”“ Grupos y Extras abiertos (local)');
  }
}

function updateLockBadgeInicio(){
  var badge = document.getElementById('lock-badge-inicio');
  if(!badge) return;
  if(pronosticosBloqueados){
    badge.innerHTML = 'рџ”’ <strong style="color:#f87171">Grupos y Extras CERRADOS</strong> вЂ” El Organizador bloqueГі la carga inicial. Las fases eliminatorias siguen abiertas cuando se conozcan los cruces.';
    badge.style.borderColor = 'rgba(239,68,68,.3)';
    badge.style.background  = 'rgba(239,68,68,.06)';
  } else {
    badge.innerHTML = 'рџ’Ў <strong style="color:var(--gold)">Tip:</strong> TocГЎ el botГіn verde <strong style="color:var(--green-light)">"Mis PronГіsticos"</strong> para cargar tus predicciones. CГіdigo del grupo: <strong style="color:var(--gold)">'+ _GC +'</strong>';
    badge.style.borderColor = 'rgba(201,162,39,.2)';
    badge.style.background  = 'var(--bg2)';
  }
}

// Art. 14 & 15 вЂ” aplicar bonus cierre de grupos
function aplicarCierre(leader, last){
  if(!confirm('Aplicar clausulas de cierre?  +5 pts a '+last+',  -5 pts a '+leader+'.')) return;
  var bonusCierre = RESULTADOS_OFICIALES.bonusCierre || {};
  bonusCierre[last]   = (bonusCierre[last]   || 0) + 5;
  bonusCierre[leader] = (bonusCierre[leader] || 0) - 5;
  RESULTADOS_OFICIALES.bonusCierre = bonusCierre;
  // Guardar en Firebase
  db.collection('pronosticos').doc('ORGANIZADOR').update({
    'pronosticos.bonusCierre': bonusCierre,
    updatedAt: new Date().toISOString()
  }).then(function(){
    showToast('вљЎ ClГЎusulas aplicadas: +5 a '+last+', в€’5 a '+leader);
    updateTabla();
    renderAdminPanel();
  }).catch(function(err){
    // Si falla update, intentar set completo
    var oficiales = Object.assign({}, RESULTADOS_OFICIALES);
    oficiales.bonusCierre = bonusCierre;
    db.collection('pronosticos').doc('ORGANIZADOR').set({
      nombre:'ORGANIZADOR', pronosticos:oficiales, updatedAt:new Date().toISOString()
    }).then(function(){
      showToast('вљЎ ClГЎusulas aplicadas');
      updateTabla(); renderAdminPanel();
    }).catch(function(e){ showToast('вќЊ Error: '+e.message); });
  });
}

function saveOficiales(){
  // Preservar siempre el estado de bloqueo вЂ” NO debe cambiar al publicar resultados
  var oficiales={
    extras:{},
    bonusCierre:     RESULTADOS_OFICIALES.bonusCierre     || {},
    pronosticosBloqueados: pronosticosBloqueados           // в†ђ siempre se mantiene
  };

  // Resultados de partidos
  Object.keys(FIXTURE).forEach(function(phase){
    FIXTURE[phase].forEach(function(m){
      var h=document.getElementById('of-h-'+m.id);
      var a=document.getElementById('of-a-'+m.id);
      if(h&&a&&h.value!==''&&a.value!=='')oficiales[m.id]={h:parseInt(h.value),a:parseInt(a.value)};
    });
  });

  // Extras (autores de gol + predicciones generales)
  EXTRAS_DATA.arg.concat(EXTRAS_DATA.grid).forEach(function(e){
    var el=document.getElementById('of-ext-'+e.id);
    if(el&&el.value.trim()!=='')oficiales.extras[e.id]=el.value.trim();
  });

  // Partidos de Argentina en eliminatoria (checkboxes)
  var argPartidos=[];
  var elimPhases=['r32','r16','cuartos','semis','final'];
  elimPhases.forEach(function(ph){
    if(!FIXTURE[ph])return;
    FIXTURE[ph].forEach(function(m){
      var cb=document.getElementById('argp-'+m.id);
      if(cb&&cb.checked) argPartidos.push(m.id);
    });
  });
  oficiales.argPartidos = argPartidos;

  db.collection('pronosticos').doc('ORGANIZADOR').set({
    nombre:'ORGANIZADOR', pronosticos:oficiales, updatedAt:new Date().toISOString()
  }).then(function(){
    RESULTADOS_OFICIALES = Object.assign({extras:{},bonusCierre:{},argPartidos:[]}, oficiales);
    updateTabla(); updateStats();
    showToast('вњ… Resultados publicados');
  }).catch(function(err){showToast('вќЊ Error: '+err.message);});
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  PUNTOS вЂ” Sistema Arts. 9 al 20
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

// IDs de partidos de Argentina por fase
var ARG_GRUPOS  = ['J1','J3','J5'];
var ARG_ELIM    = {
  r32:   ['R32-12','R32-14'],
  r16:   ['R16-5','R16-6','R16-7','R16-8'],
  cuartos:['QF-1','QF-2','QF-3','QF-4'],
  semis: ['SF-1','SF-2'],
  final: ['FINAL'],
  tercer:['3RD']
};

function getPhaseOf(id){
  var phases=Object.keys(FIXTURE);
  for(var i=0;i<phases.length;i++){
    for(var j=0;j<FIXTURE[phases[i]].length;j++){
      if(FIXTURE[phases[i]][j].id===id)return phases[i];
    }
  }
  return null;
}

function isArgMatch(id, phase){
  // Los partidos de arg de grupos los conocemos
  if(ARG_GRUPOS.indexOf(id)>=0) return true;
  // En eliminatorias: si RESULTADOS_OFICIALES marca que Argentina jugГі ese partido
  // Se indica via RESULTADOS_OFICIALES.argPartidos = ['R32-12', 'QF-3', ...]
  var argElim = RESULTADOS_OFICIALES.argPartidos || [];
  return argElim.indexOf(id)>=0;
}

function calcPuntos(user){
  var pts=0, exactos=0, parciales=0, errores=0;
  var ups=pronosticos[user]||{};

  Object.keys(ups).forEach(function(id){
    if(id==='extras')return;
    var p=ups[id], r=RESULTADOS_OFICIALES[id];
    if(!p||!r||r.h===''||r.a==='')return;

    var phase=getPhaseOf(id);
    var isGrupos=(phase==='grupos');
    var esArg=isArgMatch(id, phase);
    var esPleno=(p.h===r.h && p.a===r.a);
    var esAcierto=(p.h>p.a&&r.h>r.a)||(p.h<p.a&&r.h<r.a)||(p.h===p.a&&r.h===r.a);

    if(isGrupos){
      // Art. 09 вЂ” 2pts acierto
      if(esAcierto){
        pts+=2; parciales++;
        // Art. 10 вЂ” +1 pleno +1 x gol
        if(esPleno){ pts+=1; pts+=(r.h+r.a); exactos++; }
        // Art. 11 вЂ” +1 arg acertado
        if(esArg) pts+=1;
        // Art. 12 вЂ” +1 pleno argento
        if(esArg&&esPleno) pts+=1;
      } else { errores++; }

    } else {
      // Art. 16 вЂ” puntos base eliminatoria
      var base=0;
      if(id==='FINAL') base=13;
      else if(id==='3RD') base=11;
      else if(phase==='semis') base=9;
      else if(phase==='cuartos') base=7;
      else base=5; // r32 y r16

      if(esAcierto){
        pts+=base; parciales++;
        // Art. 17 вЂ” +2 pleno +1 x gol
        if(esPleno){ pts+=2; pts+=(r.h+r.a); exactos++; }
        // Art. 18 вЂ” bonus Argentina
        if(esArg){
          if(id==='FINAL') pts+=2;
          else if(id!=='3RD') pts+=1;
        }
        // Art. 19 вЂ” pleno argento elim: +5
        if(esArg&&esPleno) pts+=5;
      } else {
        errores++;
        // Art. 18 вЂ” penalidad: pronosticГі Argentina en 3er puesto
        // Se detecta: el 3RD estГЎ jugado, Argentina jugГі ese partido, y el usuario acertГі el partido de ARG en semis
        // Implementado automГЎticamente: si el org marca argPartidos y incluye '3RD'
        if(id==='3RD' && esArg && RESULTADOS_OFICIALES['3RD']){
          // Si Argentina estГЎ en el 3rd pero el usuario NO acertГі el resultado, igual pierde 5
          // (segГєn art. ubica a Argentina en tal instancia)
          // Esto se aplica si el usuario pronosticГі la semi de Argentina correctamente
          pts-=5;
        }
      }
    }
  });

  // в”Ђв”Ђ EXTRAS в”Ђв”Ђ
  var pExt=(ups.extras||{}), rExt=(RESULTADOS_OFICIALES.extras||{});

  // Predicciones generales: 15pts c/u
  EXTRAS_DATA.grid.forEach(function(e){
    if(pExt[e.id]&&rExt[e.id]){
      if(String(pExt[e.id]).trim().toLowerCase()===String(rExt[e.id]).trim().toLowerCase()) pts+=15;
    }
  });

  // Autores gol argentino (Arts. 13/20) вЂ” hasta 5 por partido
  EXTRAS_DATA.arg.forEach(function(e){
    if(pExt[e.id]&&rExt[e.id]){
      if(String(pExt[e.id]).trim().toLowerCase()===String(rExt[e.id]).trim().toLowerCase()) pts+=e.pts;
    }
  });

  // Art. 14/15 bonus cierre grupos (se aplica en updateTabla)
  return{pts:pts, exactos:exactos, parciales:parciales, errores:errores};
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  TABLA
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
function updateTabla(){
  var tbody=document.getElementById('tabla-body');
  var users=Object.keys(pronosticos);
  if(!users.length){tbody.innerHTML='<tr><td colspan="6" style="text-align:center;color:var(--text3);padding:32px">AГєn no hay datos. ВЎCargГЎ tus pronГіsticos!</td></tr>';return;}

  var bonusCierre = RESULTADOS_OFICIALES.bonusCierre || {};

  var rows=users.map(function(u){
    var r=Object.assign({u:u},calcPuntos(u));
    r.pts += (bonusCierre[u] || 0); // Art. 14 & 15
    r.bonus = bonusCierre[u] || 0;
    return r;
  });
  rows.sort(function(a,b){return b.pts-a.pts||b.exactos-a.exactos;});
  tbody.innerHTML=rows.map(function(r,i){
    var rank=i===0?'<span class="rank-gold">рџҐ‡</span>':i===1?'<span class="rank-silver">рџҐ€</span>':i===2?'<span class="rank-bronze">рџҐ‰</span>':'<span class="rank-num">'+(i+1)+'</span>';
    var bonusBadge='';
    if(r.bonus>0) bonusBadge='<span style="font-size:10px;color:#4ade80;margin-left:6px;background:rgba(74,222,128,.1);padding:1px 6px;border-radius:10px">+'+r.bonus+' рџЏ…</span>';
    if(r.bonus<0) bonusBadge='<span style="font-size:10px;color:#f87171;margin-left:6px;background:rgba(248,113,113,.1);padding:1px 6px;border-radius:10px">'+r.bonus+' вљ пёЏ</span>';
    return '<tr><td>'+rank+'</td>'+
      '<td><div class="player-cell"><div class="avatar">'+ini(r.u)+'</div>'+r.u+bonusBadge+'</div></td>'+
      '<td>'+r.exactos+'</td><td>'+r.parciales+'</td><td>'+r.errores+'</td>'+
      '<td><span class="pts-big">'+r.pts+'</span></td></tr>';
  }).join('');
}

function updateStats(){
  var elP=document.getElementById('st-participantes');
  var elPr=document.getElementById('st-pronosticos');
  var total=0;
  Object.values(pronosticos).forEach(function(p){
    Object.keys(p).forEach(function(k){total+=k==='extras'?Object.keys(p[k]).length:1;});
  });
  if(elP) elP.textContent=Object.keys(pronosticos).length;
  if(elPr) elPr.textContent=total;
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  TODOS
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
function updateMatchSelector(){
  var sel=document.getElementById('match-selector');
  if(!sel)return;
  var cur=sel.value;
  sel.innerHTML='<option value="">вЂ” SeleccionГЎ un partido вЂ”</option>';
  Object.keys(FIXTURE).forEach(function(phase){
    FIXTURE[phase].forEach(function(m){
      var opt=document.createElement('option');
      opt.value=m.id;
      opt.textContent=(m.local+' vs '+m.visita+' ('+m.fecha+')');
      sel.appendChild(opt);
    });
  });
  if(cur)sel.value=cur;
}

function renderTodos(){
  var id=document.getElementById('match-selector').value;
  var tbody=document.getElementById('todos-body');
  if(!id){tbody.innerHTML='<tr><td colspan="3" style="text-align:center;color:var(--text3);padding:32px">SeleccionГЎ un partido</td></tr>';return;}
  var users=Object.keys(pronosticos);
  if(!users.length){tbody.innerHTML='<tr><td colspan="3" style="text-align:center;color:var(--text3);padding:32px">Sin participantes aГєn</td></tr>';return;}
  var oficial=RESULTADOS_OFICIALES[id];
  var rows=users.map(function(u){
    var p=pronosticos[u][id];
    if(!p)return'';
    var resText=oficial?(oficial.h+' вЂ” '+oficial.a):'вЂ”';
    return'<tr><td><div class="player-cell"><div class="avatar">'+ini(u)+'</div>'+u+'</div></td><td style="font-weight:600;color:var(--gold-light)">'+p.h+' вЂ” '+p.a+'</td><td style="color:var(--text2)">'+resText+'</td></tr>';
  }).join('');
  tbody.innerHTML=rows||'<tr><td colspan="3" style="text-align:center;color:var(--text3);padding:32px">Nadie cargГі pronГіstico para este partido</td></tr>';
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  NAV
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
// в”Ђв”Ђ NAV DROPDOWN в”Ђв”Ђ
function toggleMenu(){
  var dd=document.getElementById('nav-dropdown');
  var arrow=document.getElementById('menu-arrow');
  dd.classList.toggle('open');
  arrow.classList.toggle('open');
}

function navGo(id, btn){
  // Close dropdown
  document.getElementById('nav-dropdown').classList.remove('open');
  document.getElementById('menu-arrow').classList.remove('open');
  // Activate section
  document.querySelectorAll('.section').forEach(function(s){s.classList.remove('active');});
  document.querySelectorAll('.nav-drop-btn').forEach(function(b){b.classList.remove('active');});
  document.getElementById(id).classList.add('active');
  if(btn) btn.classList.add('active');
  if(id==='tabla') updateTabla();
  if(id==='todos'){ updateMatchSelector(); renderTodos(); }
}

// Close dropdown when clicking outside
document.addEventListener('click', function(e){
  var trigger=document.getElementById('menu-trigger');
  var dd=document.getElementById('nav-dropdown');
  if(dd && trigger && !trigger.contains(e.target) && !dd.contains(e.target)){
    dd.classList.remove('open');
    document.getElementById('menu-arrow').classList.remove('open');
  }
});

function showSection(id,btn){
  navGo(id, document.getElementById('navbtn-'+id));
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  MODAL
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
function openPronosticos(){
  if(!currentUser){openLogin();return;}
  document.getElementById('modal-overlay').classList.add('open');
  renderMatches(currentPhase);
  // Show lock banner inside modal if blocked
  updateLockBanner();
}

function updateLockBanner(){
  var banner = document.getElementById('lock-banner');
  var saveBtn = document.getElementById('save-pronos-btn');
  if(!banner) return;
  var fasesBlockeadas = ['grupos','extras'];
  var estaFaseBloqueada = pronosticosBloqueados && currentUser !== 'ORGANIZADOR' && fasesBlockeadas.indexOf(currentPhase) >= 0;
  if(estaFaseBloqueada){
    banner.style.display = 'flex';
    if(saveBtn){ saveBtn.disabled = true; saveBtn.style.opacity = '0.4'; saveBtn.style.cursor = 'not-allowed'; }
  } else {
    banner.style.display = 'none';
    if(saveBtn){ saveBtn.disabled = false; saveBtn.style.opacity = '1'; saveBtn.style.cursor = 'pointer'; }
  }
}
function closeModal(){document.getElementById('modal-overlay').classList.remove('open');}
function closeModalOutside(e){if(e.target===document.getElementById('modal-overlay'))closeModal();}
function setPhase(el,phase){
  document.querySelectorAll('.phase-tab').forEach(function(b){b.classList.remove('active');});
  el.classList.add('active');
  currentPhase=phase;
  renderMatches(phase);
  updateLockBanner(); // Actualizar banner segГєn la fase
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  LOGIN
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
function openLogin(){document.getElementById('login-overlay').classList.add('open');}
function closeLogin(){document.getElementById('login-overlay').classList.remove('open');}
// в”Ђв”Ђ Hashes SHA-256 (las claves reales nunca aparecen en el cГіdigo) в”Ђв”Ђ
var _AH = '64e48f3bf07307f751c02213b95e0b5e1e8351597dfbe12bce5cbf115591ce3f';
var _GC = atob('TVVOREFMMDI2');
var _PH = 'db3d76dbd094ec1b25f765e8e9c69fbdb1718c4689bed4197ab7f0454fd00e70';
function _h256(s){
  return crypto.subtle.digest('SHA-256',new TextEncoder().encode(s))
    .then(function(b){return Array.from(new Uint8Array(b)).map(function(x){return x.toString(16).padStart(2,'0')}).join('');});
}

function doLogin(){
  var nombre = document.getElementById('login-nombre').value.trim();
  var codigo = document.getElementById('login-codigo').value.trim().toUpperCase();
  _h256(codigo).then(function(h){
    if(h === _AH){
      currentUser='ORGANIZADOR';
      localStorage.setItem('prodeUser',currentUser);
      closeLogin(); updateHeaderUser();
      navGo('resultados', document.getElementById('navbtn-resultados'));
      renderAdminPanel();
      showToast('рџ‘‘ Modo Organizador Activado');
      return;
    }
    if(!nombre){showToast('вљ пёЏ IngresГЎ tu nombre');return;}
    if(h !== _PH){showToast('вќЊ CГіdigo incorrecto');return;}
    currentUser=nombre;
    localStorage.setItem('prodeUser',currentUser);
    if(!pronosticos[currentUser])pronosticos[currentUser]={};
    closeLogin(); updateHeaderUser(); updateStats();
    showToast('вљЅ ВЎBienvenido, '+nombre+'!');
    setTimeout(openPronosticos,400);
  });
}
function updateHeaderUser(){
  var area=document.getElementById('header-user-area');
  if(!currentUser)return;
  area.innerHTML='<div class="user-avatar" title="'+currentUser+'">'+ini(currentUser)+'</div><span style="font-size:13px;color:var(--text2)">'+currentUser+'</span>';
  var info=document.getElementById('modal-user-info');
  if(info)info.textContent='Jugando como: '+currentUser;
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  FIRESTORE SYNC EN TIEMPO REAL
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
db.collection('pronosticos').onSnapshot(function(snapshot){
  pronosticos={};
  snapshot.forEach(function(snap){
    var d=snap.data();
    if(d.nombre==='ORGANIZADOR'){
      var incoming = d.pronosticos || {};
      RESULTADOS_OFICIALES = Object.assign({extras:{},bonusCierre:{},argPartidos:[],pronosticosBloqueados:false}, incoming);
      if(!RESULTADOS_OFICIALES.extras)      RESULTADOS_OFICIALES.extras      = {};
      if(!RESULTADOS_OFICIALES.bonusCierre) RESULTADOS_OFICIALES.bonusCierre = {};
      if(!RESULTADOS_OFICIALES.argPartidos) RESULTADOS_OFICIALES.argPartidos = [];
      // El estado de bloqueo viene SIEMPRE de Firebase вЂ” es la fuente de verdad
      pronosticosBloqueados = RESULTADOS_OFICIALES.pronosticosBloqueados === true;
      updateLockBanner();
      updateLockBadgeInicio();
      if(currentUser==='ORGANIZADOR') renderAdminPanel();
    } else if(d.nombre&&d.pronosticos){
      pronosticos[d.nombre]=d.pronosticos;
    }
  });
  if(currentUser&&currentUser!=='ORGANIZADOR'){
    var local=localStorage.getItem('prodeData_'+currentUser);
    if(local&&!pronosticos[currentUser]){try{pronosticos[currentUser]=JSON.parse(local);}catch(e){}}
    loadInputValues();
  }
  updateStats(); updateTabla(); updateMatchSelector(); renderTodos();
  if(currentUser==='ORGANIZADOR')renderAdminPanel();
});

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  COCOMUNICADOS
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
// Lista de comunicados вЂ” el mГЎs reciente primero.
// Para agregar uno nuevo: copiar el bloque { fecha, texto } y pegarlo al inicio del array.
var COCOMUNICADOS = [
  {
    fecha: 'Viernes 12 de Junio de 2026',
    texto: '\x3C/strong\x3E La Cocomisi\xF3n les cocomunica que hasta las 22 hs del d\xEDa de hoy, Viernes 12 de Junio de 2026, quedan abiertas las Prodicciones Extras para aquellos que no llegaron a completarlas. La Cocomisi\xF3n le hace observar a sus participantes que esta excepci\xF3n no debe ser coconfundida con tibieza. Se tom\xF3 nota de aquellos que no cumplieron a tiempo, y la Cocomisi\xF3n se reserva el derecho ser implacable a futuro.'
  }
];

function renderCocomunicados(){
  var container = document.getElementById('cocomunicados-container');
  if(!container) return;
  if(!COCOMUNICADOS.length){
    container.innerHTML = '<div class="coco-panel"><div class="coco-empty">Sin comunicados por el momento.</div></div>';
    return;
  }
  var items = COCOMUNICADOS.map(function(c, i){
    return '<div class="coco-item">' +
      '<div class="coco-body">' +
        '<div class="coco-fecha">' + c.fecha + '</div>' +
        '<div class="coco-texto">' + c.texto.replace(/^\u{1F965}\s*/u,'') + '</div>' +
      '</div>' +
    '</div>';
  }).join('');
  container.innerHTML =
    '<div class="coco-panel">' +
      '<div class="coco-header">' +
        '<span style="font-size:22px">\u{1F965}</span>' +
        '<span class="coco-header-title">Cocomunicados</span>' +
        '<span class="coco-header-sub">' + COCOMUNICADOS.length + ' comunicado' + (COCOMUNICADOS.length !== 1 ? 's' : '') + '</span>' +
      '</div>' +
      '<div class="coco-list">' + items + '</div>' +
    '</div>';
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  INIT
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
// Populate datalist with Argentina squad
(function(){
  var dl = document.getElementById('dl-arg-squad');
  if(dl){
    ARG_SQUAD.forEach(function(name){
      var opt = document.createElement('option');
      opt.value = name;
      dl.appendChild(opt);
    });
  }
})();

document.addEventListener('DOMContentLoaded', function(){
  updateHeaderUser();
  updateMatchSelector();
  renderCocomunicados();
  if(currentUser==='ORGANIZADOR') renderAdminPanel();
});
</script>
</body>
</html>
