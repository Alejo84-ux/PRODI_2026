    </div>
  </div>

  <div id="todos" class="section">
    <div class="card">
      <div class="card-header">
        <div class="card-title"><div class="dot"></div>PronГіsticos de todos</div>
        <select id="match-selector" onchange="renderTodos()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:8px;padding:5px 10px;font-family:'Inter',sans-serif;font-size:12px;outline:none">
          <option value="">вЂ” SeleccionГЎ un partido вЂ”</option>
        </select>
      </div>
      <div class="tabla-wrap">
        <table class="tabla">
          <thead><tr><th>Jugador</th><th>PronГіstico</th><th>Resultado oficial</th></tr></thead>
