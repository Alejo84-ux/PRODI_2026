  <div id="tabla" class="section">
    <div class="card">
      <div class="card-header"><div class="card-title"><div class="dot"></div>Tabla de posiciones</div><span style="font-size:11px;color:var(--text3)">En tiempo real</span></div>
      <div class="tabla-wrap">
        <table class="tabla">
          <thead><tr><th>#</th><th>Jugador</th><th>Exactos</th><th>Parciales</th><th>Errores</th><th>Pts</th></tr></thead>
          <tbody id="tabla-body"><tr><td colspan="6" style="text-align:center;color:var(--text3);padding:32px">AГєn no hay datos</td></tr></tbody>
        </table>
