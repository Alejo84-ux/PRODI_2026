<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prodi Mundial 2026 🏆</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

<!-- Firebase CDN (versión compat — no requiere módulos ES) -->
<script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-firestore-compat.js"></script>

<style>
  :root {
    --green-dark:#0a3d1f; --green-mid:#1a6b3c; --green-light:#2d9e5c;
    --gold:#c9a227; --gold-light:#f0c94a;
    --bg:#0d1117; --bg2:#161b22; --bg3:#21262d;
    --border:rgba(255,255,255,0.08); --border-hover:rgba(255,255,255,0.16);
    --text:#e6edf3; --text2:#8b949e; --text3:#484f58;
    --radius:10px; --radius-lg:16px;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:14px}

  .site-header{background:linear-gradient(180deg,#0a1f0f 0%,var(--bg) 100%);border-bottom:1px solid var(--border);padding:0 1.5rem;position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;height:60px}
  .logo{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:2px;color:var(--gold);display:flex;align-items:center;gap:10px}
  .logo span{color:var(--text)}
  .header-nav{display:flex;gap:4px}
  .hnav-btn{padding:6px 14px;border-radius:8px;border:none;background:transparent;color:var(--text2);font-size:13px;cursor:pointer;font-family:'Inter',sans-serif;transition:all .15s}
  .hnav-btn:hover{background:var(--bg3);color:var(--text)}
  .hnav-btn.active{background:var(--green-mid);color:#fff}
  .header-user { display:flex; align-items:center; gap:10px; margin-right: 20px; } /* Ajusta el margen según prefieras */
  .user-avatar{width:32px;height:32px;border-radius:50%;background:var(--green-mid);display:flex;align-items:center;justify-content:center;font-weight:600;font-size:12px;color:#fff;cursor:pointer}
  .btn-login{padding:6px 16px;border-radius:8px;background:var(--green-mid);color:#fff;border:none;font-family:'Inter',sans-serif;font-size:13px;cursor:pointer;font-weight:500;transition:background .15s}
  .btn-login:hover{background:var(--green-light)}

  .hero{background:linear-gradient(135deg,rgba(0,0,0,.65) 0%,rgba(0,0,0,.65) 100%),url('fondo.jpg') center/cover no-repeat;border-bottom:1px solid var(--border);padding:3rem 1.5rem 2rem;text-align:center;position:relative;overflow:hidden}
  .hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(201,162,39,.15);border:1px solid rgba(201,162,39,.3);border-radius:20px;padding:4px 14px;font-size:12px;color:var(--gold);margin-bottom:1rem;font-weight:500;letter-spacing:.5px}
  .hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,8vw,64px);letter-spacing:3px;line-height:1;color:var(--text);margin-bottom:.5rem}
  .hero h1 .accent{color:var(--gold)}
  .hero p{color:var(--text2);font-size:15px;margin-bottom:1.5rem}
  .hero-stats{display:flex;justify-content:center;gap:2rem;flex-wrap:wrap}
  .hero-stat{text-align:center}
  .hero-stat-val{font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--gold-light);line-height:1}
  .hero-stat-lbl{font-size:11px;color:var(--text3);margin-top:2px;text-transform:uppercase;letter-spacing:.5px}

  .main{max-width:1000px;margin:0 auto;padding:1.5rem}
  .section{display:none}
  .section.active{display:block}

  .card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden}
  .card-header{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
  .card-title{font-size:13px;font-weight:600;color:var(--text);text-transform:uppercase;letter-spacing:.5px;display:flex;align-items:center;gap:8px}
  .card-title .dot{width:6px;height:6px;border-radius:50%;background:var(--green-light)}

  .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:1.5rem}
  .stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:16px}
  .stat-val{font-family:'Bebas Neue',sans-serif;font-size:32px;color:var(--gold);line-height:1}
  .stat-lbl{font-size:11px;color:var(--text3);margin-top:4px;text-transform:uppercase;letter-spacing:.5px}

  .tabla-wrap{overflow-x:auto}
  .tabla{width:100%;border-collapse:collapse;font-size:13px}
  .tabla th{padding:10px 14px;text-align:left;color:var(--text3);font-weight:500;font-size:11px;text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);white-space:nowrap}
  .tabla td{padding:12px 14px;border-bottom:1px solid var(--border);color:var(--text)}
  .tabla tr:last-child td{border-bottom:none}
  .tabla tr:hover td{background:rgba(255,255,255,.02)}
  .rank-num{font-weight:600;color:var(--text3);font-size:13px}
  .rank-gold{color:var(--gold);font-size:16px}
  .rank-silver{color:#aaa;font-size:16px}
  .rank-bronze{color:#cd7f32;font-size:16px}
  .pts-big{font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--green-light)}
  .player-cell{display:flex;align-items:center;gap:10px}
  .avatar{width:30px;height:30px;border-radius:50%;background:var(--green-dark);border:1px solid var(--green-mid);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(--green-light);flex-shrink:0}

  .modal-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);overflow-y:auto;padding:1rem}
  .modal-overlay.open{display:flex;align-items:flex-start;justify-content:center}
  .modal{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);width:100%;max-width:720px;margin:auto;animation:slideUp .25s ease}
  @keyframes slideUp{from{transform:translateY(30px);opacity:0}to{transform:translateY(0);opacity:1}}
  .modal-header{padding:18px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--bg2);border-radius:var(--radius-lg) var(--radius-lg) 0 0;z-index:10}
  .modal-title{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:1px;color:var(--gold)}
  .modal-close{width:32px;height:32px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text2);cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;transition:all .15s;font-family:'Inter',sans-serif}
  .modal-close:hover{background:rgba(239,68,68,.15);color:#f87171;border-color:rgba(239,68,68,.3)}
  .modal-body{padding:20px}

  .phase-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px}
  .phase-tab{padding:6px 14px;border-radius:20px;border:1px solid var(--border);background:transparent;color:var(--text2);font-family:'Inter',sans-serif;font-size:12px;cursor:pointer;transition:all .15s;font-weight:500}
  .phase-tab:hover{border-color:var(--border-hover);color:var(--text)}
  .phase-tab.active{background:var(--green-mid);color:#fff;border-color:var(--green-mid)}

  .grupo-block{margin-bottom:20px}
  .grupo-label{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:1px;padding:0 0 8px}
  .match-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;margin-bottom:8px;transition:border-color .15s}
  .match-card:hover{border-color:var(--border-hover)}
  .match-card.saved{border-color:rgba(45,158,92,.4)}
  .match-top{display:flex;align-items:center;gap:10px}
  .team-block{flex:1;display:flex;align-items:center;gap:8px}
  .team-block.right{flex-direction:row-reverse}
  .team-name{font-size:13px;font-weight:500;color:var(--text)}
  .score-inputs{display:flex;align-items:center;gap:8px;flex-shrink:0}
  .score-in{width:38px;height:38px;background:var(--bg);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:16px;font-weight:600;text-align:center;outline:none;transition:border-color .15s;font-family:'Bebas Neue',sans-serif}
  .score-in:focus{border-color:var(--green-light)}
  .score-in::placeholder{color:var(--text3);font-family:'Inter',sans-serif;font-size:12px}
  .vs-sep{font-size:11px;color:var(--text3);font-weight:600}
  .match-meta{font-size:11px;color:var(--text3);margin-top:6px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}

  .btn-save{width:100%;padding:12px;background:var(--green-mid);color:#fff;border:none;border-radius:var(--radius);font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:1px;cursor:pointer;margin-top:8px;transition:background .15s}
  .btn-save:hover{background:var(--green-light)}

  .login-modal-overlay{display:none;position:fixed;inset:0;z-index:300;background:rgba(0,0,0,.8);backdrop-filter:blur(6px);align-items:center;justify-content:center;padding:1rem}
  .login-modal-overlay.open{display:flex}
  .login-modal{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);width:100%;max-width:380px;padding:32px;text-align:center;animation:slideUp .25s ease}
  .login-icon{font-size:48px;margin-bottom:16px}
  .login-modal h2{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:1px;color:var(--gold);margin-bottom:6px}
  .login-modal p{color:var(--text2);font-size:13px;margin-bottom:20px}
  .input-field{width:100%;padding:10px 14px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-family:'Inter',sans-serif;font-size:14px;outline:none;margin-bottom:10px;transition:border-color .15s}
  .input-field:focus{border-color:var(--green-light)}
  .input-field::placeholder{color:var(--text3)}
  .input-label{font-size:12px;color:var(--text2);text-align:left;display:block;margin-bottom:4px}

  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--green-dark);border:1px solid var(--green-mid);color:#fff;padding:10px 20px;border-radius:24px;font-size:13px;font-weight:500;z-index:999;opacity:0;pointer-events:none;transition:opacity .3s;white-space:nowrap}
  .toast.show{opacity:1}

 .open-pronos-btn {
    position: relative; /* Cambiamos de fixed a relative */
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%; /* Para que ocupe el ancho del contenedor */
    margin-top: 20px; /* Espacio para separarlo del recuadro de arriba */
    background: var(--green-mid);
    color: #fff;
    border: none;
    border-radius: var(--radius); /* Usamos la variable de radio definida */
    padding: 16px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all .2s;
}
.open-pronos-btn:hover {
    background: var(--green-light);
}
/* Opcional: Si quieres quitar el efecto de pulso que ahora quedará fijo */
.open-pronos-btn .pulse { display: none; }
  @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}

  .extras-layout{display:flex;gap:20px;flex-wrap:wrap;margin-top:10px}
  .extras-col{flex:1;min-width:250px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px}
  .extras-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px}
  .extra-block{background:var(--bg3);padding:12px;border-radius:8px;border:1px solid var(--border);transition:border-color .15s}
  .extra-block.saved{border-color:rgba(45,158,92,.4)}
  .extra-label{font-size:11px;color:var(--gold);margin-bottom:8px;display:block;text-transform:uppercase;font-weight:600;letter-spacing:.5px}
  .extra-in{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);border-radius:6px;padding:10px;outline:none;font-family:'Inter',sans-serif;font-size:13px;transition:border-color .15s}
  .extra-in:focus{border-color:var(--green-light)}
  .arg-row{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);padding:10px 0}
  .arg-row:last-child{border:none}
  .arg-label{font-size:13px;font-weight:500;color:var(--text)}
  .arg-in{width:140px;text-align:left;font-family:'Inter',sans-serif;font-size:13px;padding:6px 10px;background:var(--bg);border:1px solid var(--border);color:var(--text);border-radius:6px;outline:none;transition:border-color .15s}
  .arg-in:focus{border-color:var(--green-light)}

  /* ── REGLAMENTO ── */
  .regl-section { margin-bottom: 24px; }
  .regl-section-title { font-family:'Bebas Neue',sans-serif; font-size:20px; letter-spacing:1px; color:var(--gold); margin-bottom:12px; padding-bottom:6px; border-bottom:1px solid rgba(201,162,39,.3); display:flex; align-items:center; gap:8px; }
  .art-card { background:var(--bg3); border:1px solid var(--border); border-radius:var(--radius); padding:14px 16px; margin-bottom:8px; transition:border-color .15s; }
  .art-card:hover { border-color:var(--border-hover); }
  .art-num { font-family:'Bebas Neue',sans-serif; font-size:13px; color:var(--green-light); letter-spacing:1px; margin-bottom:4px; }
  .art-title { font-size:13px; font-weight:600; color:var(--text); margin-bottom:6px; }
  .art-body { font-size:13px; color:var(--text2); line-height:1.6; }
  .art-body strong { color:var(--gold); }
  .pts-pill { display:inline-block; background:rgba(201,162,39,.15); border:1px solid rgba(201,162,39,.3); color:var(--gold-light); font-family:'Bebas Neue',sans-serif; font-size:15px; border-radius:20px; padding:2px 10px; margin:0 3px; }
  .pts-pill.green { background:rgba(45,158,92,.15); border-color:rgba(45,158,92,.3); color:#4ade80; }
  .pts-pill.red { background:rgba(239,68,68,.12); border-color:rgba(239,68,68,.2); color:#f87171; }
  .pts-pill.blue { background:rgba(117,170,219,.15); border-color:rgba(117,170,219,.3); color:#75AADB; }
  .pts-table { width:100%; border-collapse:collapse; margin-top:10px; font-size:12px; }
  .pts-table th { background:var(--bg2); color:var(--text3); padding:7px 10px; text-align:left; font-weight:500; text-transform:uppercase; letter-spacing:.5px; }
  .pts-table td { padding:8px 10px; border-bottom:1px solid var(--border); color:var(--text2); }
  .pts-table tr:last-child td { border-bottom:none; }
  .pts-table td:last-child { color:var(--gold-light); font-family:'Bebas Neue',sans-serif; font-size:15px; }

  @media(max-width:520px){
    .hero h1{font-size:36px}
    .team-name{font-size:11px}
    .header-nav .hnav-btn{padding:6px 8px;font-size:12px}
  }
</style>
</head>
<body>

<header class="site-header">
  <div class="logo">⚽ <span>PRODI</span> MUNDIAL <span style="color:var(--green-light)">2026</span></div>
  <nav class="header-nav">
    <button class="hnav-btn active" onclick="showSection('inicio',this)">Inicio</button>
    <button class="hnav-btn" onclick="showSection('tabla',this)">Tabla</button>
    <button class="hnav-btn" onclick="showSection('todos',this)">Todos</button>
    <button class="hnav-btn" onclick="showSection('resultados',this)">Resultados</button>
    <button class="hnav-btn" onclick="showSection('reglamento',this)" style="color:var(--gold)">📋 Reglamento</button>
  </nav>
  <div class="header-user" id="header-user-area">
    <button class="btn-login" onclick="openLogin()">Ingresar</button>
  </div>
</header>

<div class="hero">
  <div class="hero-badge">🏆 FIFA World Cup 2026 · USA · CAN · MEX</div>
  <h1>PRODI <span class="accent">MUNDIAL</span></h1>
   <div class="hero-stats">
    <div class="hero-stat"><div class="hero-stat-val">104</div><div class="hero-stat-lbl">Partidos</div></div>
    <div class="hero-stat"><div class="hero-stat-val">48</div><div class="hero-stat-lbl">Selecciones</div></div>
    <div class="hero-stat"><div class="hero-stat-val">12</div><div class="hero-stat-lbl">Grupos</div></div>
    <div class="hero-stat"><div class="hero-stat-val">19 Jul</div><div class="hero-stat-lbl">Final</div></div>
  </div>
</div>

<main class="main">
  <div id="inicio" class="section active">
    <div class="stats-grid" style="margin-top:0">
      <div class="stat-card"><div class="stat-val" id="st-participantes">0</div><div class="stat-lbl">Participantes</div></div>
      <div class="stat-card"><div class="stat-val" id="st-pronosticos">0</div><div class="stat-lbl">Pronósticos cargados</div></div>
      <div class="stat-card"><div class="stat-val">0</div><div class="stat-lbl">Partidos jugados</div></div>
      <div class="stat-card"><div class="stat-val">11 Jun</div><div class="stat-lbl">Próximo partido</div></div>
    </div>
    
   <div style="margin-top:16px;padding:16px;background:var(--bg2);border:1px solid rgba(201,162,39,.2);border-radius:var(--radius);color:var(--text2);font-size:13px;line-height:1.6">
  ⚽ <strong style="color:var(--gold)">¡Bienvenido al PRODI 2026!</strong> La Cocomision les desea un buen Prodi, que sepan ser amigos de los plenos y gambetear los nulos.
</div>
    
    <div style="margin-top:16px" class="card">
      <div class="card-header"><div class="card-title"><div class="dot"></div>Sistema de puntos — Resumen rápido</div>
        <button onclick="showSection('reglamento',document.querySelectorAll('.hnav-btn')[4])" style="font-size:11px;color:var(--gold);background:transparent;border:1px solid rgba(201,162,39,.3);border-radius:20px;padding:3px 10px;cursor:pointer">Ver reglamento completo →</button>
      </div>
      <div style="padding:14px 18px;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px">
        <div style="background:var(--bg3);border-radius:var(--radius);padding:12px">
          <div style="font-size:11px;color:var(--gold);font-weight:600;text-transform:uppercase;margin-bottom:8px">⚽ Grupos</div>
          <div style="font-size:12px;color:var(--text2);line-height:1.8">
            Acierto ganador/empate: <strong style="color:#4ade80">2 pts</strong><br>
            + Pleno (resultado exacto): <strong style="color:#4ade80">+1 pt</strong><br>
            + Por cada gol acertado: <strong style="color:#4ade80">+1 pt</strong><br>
            + Partido Argentina acertado: <strong style="color:#75AADB">+1 pt</strong><br>
            + Pleno Argento: <strong style="color:#75AADB">+1 pt</strong><br>
            + Autor gol argentino: <strong style="color:#75AADB">+1 pt c/u</strong>
          </div>
        </div>
        <div style="background:var(--bg3);border-radius:var(--radius);padding:12px">
          <div style="font-size:11px;color:var(--gold);font-weight:600;text-transform:uppercase;margin-bottom:8px">🏆 Eliminatorias</div>
          <div style="font-size:12px;color:var(--text2);line-height:1.8">
            Octavos: <strong style="color:var(--gold)">5</strong> · Cuartos: <strong style="color:var(--gold)">7</strong> · Semis: <strong style="color:var(--gold)">9</strong><br>
            3er puesto: <strong style="color:var(--gold)">11</strong> · Final: <strong style="color:var(--gold)">13</strong><br>
            + Pleno: <strong style="color:#4ade80">+2 pts</strong> + goles<br>
            + Arg. (no 3°): <strong style="color:#75AADB">+1 pt</strong> (Final: <strong style="color:#75AADB">+2</strong>)<br>
            + Pleno Argento: <strong style="color:#75AADB">+5 pts</strong><br>
            ⚠️ Arg. en 3er puesto: <strong style="color:#f87171">−5 pts</strong>
          </div>
        </div>
        <div style="background:var(--bg3);border-radius:var(--radius);padding:12px">
          <div style="font-size:11px;color:var(--gold);font-weight:600;text-transform:uppercase;margin-bottom:8px">🎲 Cláusulas especiales</div>
          <div style="font-size:12px;color:var(--text2);line-height:1.8">
            🏅 Último al cierre grupos: <strong style="color:#4ade80">+5 pts</strong><br>
            ⚠️ Primero al cierre grupos: <strong style="color:#f87171">−5 pts</strong><br>
            Autor gol Arg. en Final: <strong style="color:#75AADB">+5 pts c/u</strong><br>
            Predicciones Extras: <strong style="color:var(--gold)">15 pts c/u</strong>
          </div>
        </div>
      </div>
    </div>
  </div><!-- /inicio -->

  <div id="tabla" class="section">
    <div class="card">
      <div class="card-header"><div class="card-title"><div class="dot"></div>Tabla de posiciones</div><span style="font-size:11px;color:var(--text3)">En tiempo real</span></div>
      <div class="tabla-wrap">
        <table class="tabla">
          <thead><tr><th>#</th><th>Jugador</th><th>Exactos</th><th>Parciales</th><th>Errores</th><th>Pts</th></tr></thead>
          <tbody id="tabla-body"><tr><td colspan="6" style="text-align:center;color:var(--text3);padding:32px">Aún no hay datos</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="todos" class="section">
    <div class="card">
