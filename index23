var ARG_IDS = ['J1','J3','J5','R32-12','R32-14','QF-1','QF-2','QF-3','QF-4','SF-1','SF-2','3RD','FINAL'];

// Puntos base por fase eliminatoria (Art. 16)
var ELIM_PTS = {
  r32:5, r16:5, cuartos:7, semis:9, '3RD':11, 'FINAL':13
};

function getPhaseOf(id){
  var phases=Object.keys(FIXTURE);
  for(var i=0;i<phases.length;i++){
    var ph=phases[i];
    for(var j=0;j<FIXTURE[ph].length;j++){
      if(FIXTURE[ph][j].id===id)return ph;
    }
  }
  return null;
}

function isArgMatch(id){
  return ARG_IDS.indexOf(id)>=0;
}

function aciertoGanador(p,r){
  // true si acertó ganador o empate
  return (p.h>p.a&&r.h>r.a)||(p.h<p.a&&r.h<r.a)||(p.h===p.a&&r.h===r.a);
}

function calcPuntos(user){
  var pts=0, exactos=0, parciales=0, errores=0;
  var ups=pronosticos[user]||{};

  Object.keys(ups).forEach(function(id){
    if(id==='extras')return;
    var p=ups[id], r=RESULTADOS_OFICIALES[id];
    if(!p||!r)return;

    var phase=getPhaseOf(id);
    var isGrupos=phase==='grupos';
    var isArg=isArgMatch(id);
    var esPleno=(p.h===r.h&&p.a===r.a);
    var esAcierto=aciertoGanador(p,r);
    var ganador_acertado = esAcierto; // acierto en ganador o empate

    if(isGrupos){
      // Art. 09 — 2 pts por acierto ganador/empate
      if(ganador_acertado){
        pts+=2; parciales++;
        // Art. 10 — +1 pleno, +1 por cada gol
        if(esPleno){
          pts+=1; // pleno
          pts+=(r.h+r.a); // goles acertados
          exactos++;
        }
        // Art. 11 — +1 si es partido Argentina acertado
        if(isArg) pts+=1;
        // Art. 12 — +1 si es pleno argento
        if(isArg&&esPleno) pts+=1;
      } else {
        errores++;
      }

    } else {
      // FASE ELIMINATORIA
      var basePts=0;
      if(phase==='r32'||phase==='r16') basePts=5;
      else if(phase==='cuartos') basePts=7;
      else if(phase==='semis') basePts=9;
      else if(id==='3RD') basePts=11;
      else if(id==='FINAL') basePts=13;

      if(ganador_acertado){
        // Art. 16 — puntos base por fase
        pts+=basePts; parciales++;
        // Art. 17 — +2 pleno, +goles
        if(esPleno){
          pts+=2;
          pts+=(r.h+r.a);
          exactos++;
        }
        // Art. 18 — bonus Argentina
        if(isArg){
          if(id==='FINAL') pts+=2;       // final: +2
          else if(id!=='3RD') pts+=1;    // otras instancias: +1 (excepto 3er puesto)
        }
        // Art. 19 — pleno argento eliminatoria: +5
        if(isArg&&esPleno) pts+=5;
      } else {
        errores++;
        // Art. 18 — poner Argentina en 3er puesto: -5
        if(id==='3RD'&&isArg){
          // Si el usuario pronosticó a Argentina llegando al 3er puesto
          // (es decir la tiene como local o visita en ese partido)
          // Nota: como la estructura es "Per. SF X", lo manejamos via extras
          // Esta penalidad la aplica el organizador manualmente por ahora
        }
      }
    }
  });

  // ── EXTRAS ──
  var pExt=(ups.extras||{}),rExt=(RESULTADOS_OFICIALES.extras||{});

  // Predicciones generales (15 pts c/u)
  EXTRAS_DATA.grid.forEach(function(e){
    if(pExt[e.id]&&rExt[e.id]){
      var uv=String(pExt[e.id]).trim().toLowerCase();
      var rv=String(rExt[e.id]).trim().toLowerCase();
      if(uv===rv) pts+=15;
    }
  });

  // Art. 13 / Art. 20 — Autores de gol argentino
  // arg_1..arg_3 = fase de grupos (+1 cada uno)
  // arg_8 = octavos (+1), arg_4 = cuartos (+1), arg_S = semis (+1)
  // arg_F = final (+5 cada uno según Art. 20)
  var argGolPts={arg_1:1,arg_2:1,arg_3:1,arg_8:1,arg_4:1,arg_S:1,arg_F:5};
  Object.keys(argGolPts).forEach(function(k){
    if(pExt[k]&&rExt[k]){
      var uv=String(pExt[k]).trim().toLowerCase();
      var rv=String(rExt[k]).trim().toLowerCase();
      if(uv===rv) pts+=argGolPts[k];
    }
  });

  return{pts:pts,exactos:exactos,parciales:parciales,errores:errores};
}

// Art. 14 & 15 — Bonus/Penalidad cierre de grupos (lo aplica el organizador)
// Se registra en RESULTADOS_OFICIALES.bonusCierre = { usuario: pts }
function aplicarBonusCierre(){
  var bonus=RESULTADOS_OFICIALES.bonusCierre||{};
  return bonus; // { nombre: +5 o -5 }
}

// ══════════════════════════════════════════
//  TABLA
// ══════════════════════════════════════════
function updateTabla(){
  var tbody=document.getElementById('tabla-body');
  var users=Object.keys(pronosticos);
  if(!users.length){tbody.innerHTML='<tr><td colspan="6" style="text-align:center;color:var(--text3);padding:32px">Aún no hay datos. ¡Cargá tus pronósticos!</td></tr>';return;}
  var bonus=aplicarBonusCierre();
  var rows=users.map(function(u){
    var r=Object.assign({u:u},calcPuntos(u));
    r.pts+=(bonus[u]||0); // Art. 14 & 15
    return r;
  });
  rows.sort(function(a,b){return b.pts-a.pts||b.exactos-a.exactos;});
  tbody.innerHTML=rows.map(function(r,i){
    var rank=i===0?'<span class="rank-gold">🥇</span>':i===1?'<span class="rank-silver">🥈</span>':i===2?'<span class="rank-bronze">🥉</span>':'<span class="rank-num">'+(i+1)+'</span>';
    var bonusUser=bonus[r.u]||0;
    var bonusBadge=bonusUser>0?'<span style="font-size:10px;color:#4ade80;margin-left:4px">+'+bonusUser+'🏅</span>':bonusUser<0?'<span style="font-size:10px;color:#f87171;margin-left:4px">'+bonusUser+'⚠️</span>':'';
    return '<tr><td>'+rank+'</td><td><div class="player-cell"><div class="avatar">'+ini(r.u)+'</div>'+r.u+bonusBadge+'</div></td><td>'+r.exactos+'</td><td>'+r.parciales+'</td><td>'+r.errores+'</td><td><span class="pts-big">'+r.pts+'</span></td></tr>';
  }).join('');
}

function updateStats(){
  document.getElementById('st-participantes').textContent=Object.keys(pronosticos).length;
  var total=0;
  Object.values(pronosticos).forEach(function(p){
    Object.keys(p).forEach(function(k){total+=k==='extras'?Object.keys(p[k]).length:1;});
  });
  document.getElementById('st-pronosticos').textContent=total;
}

