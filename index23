function matchCard(m){
  var saved = currentUser && pronosticos[currentUser] && pronosticos[currentUser][m.id];
  var hv = saved ? saved.h : '';
  var av = saved ? saved.a : '';
  var lbl = m.label ? '<div style="font-size:11px;color:var(--gold);margin-bottom:4px;font-weight:600">'+m.label+'</div>' : '';
  return '<div class="match-card'+(saved?' saved':'')+'" id="mc-'+m.id+'">'+lbl+
    '<div class="match-top">'+
      '<div class="team-block right"><span class="team-name">'+m.local+'</span></div>'+
      '<div class="score-inputs">'+
        '<input type="number" min="0" max="20" class="score-in" id="h-'+m.id+'" value="'+hv+'" onchange="markChanged(\''+m.id+'\')" placeholder="-">'+
        '<span class="vs-sep">VS</span>'+
        '<input type="number" min="0" max="20" class="score-in" id="a-'+m.id+'" value="'+av+'" onchange="markChanged(\''+m.id+'\')" placeholder="-">'+
      '</div>'+
      '<div class="team-block"><span class="team-name">'+m.visita+'</span></div>'+
    '</div>'+
    '<div class="match-meta"><span>📅 '+m.fecha+' · '+m.hora+'</span><span>📍 '+m.sede+'</span></div>'+
  '</div>';
}

function renderMatches(phase){
  var container=document.getElementById('matches-container');
  if(phase==='extras'){renderExtras(container);return;}
  var matches=FIXTURE[phase]; if(!matches)return;
  if(phase==='grupos'){
    var groups={};
    matches.forEach(function(m){if(!groups[m.grupo])groups[m.grupo]=[];groups[m.grupo].push(m);});
    container.innerHTML=Object.keys(groups).map(function(g){
      return '<div class="grupo-block"><div class="grupo-label">Grupo '+g+'</div>'+groups[g].map(matchCard).join('')+'</div>';
    }).join('');
  } else {
    container.innerHTML=matches.map(matchCard).join('');
  }
  loadInputValues();
}

function renderExtras(container){
  var argHtml=EXTRAS_DATA.arg.map(function(e){
    return '<div class="arg-row"><span class="arg-label">'+e.label+'</span>'+
      '<input type="text" class="arg-in" id="'+e.id+'" placeholder="Ej: Messi" onchange="markExtraChanged(\''+e.id+'\')"></div>';
  }).join('');
  var gridHtml=EXTRAS_DATA.grid.map(function(e){
    return '<div class="extra-block" id="eb-'+e.id+'"><label class="extra-label">'+e.label+'</label>'+
      '<input type="'+(e.type||'text')+'" class="extra-in" id="'+e.id+'" placeholder="..." onchange="markExtraChanged(\''+e.id+'\')"></div>';
  }).join('');
  container.innerHTML='<div class="extras-layout">'+
    '<div class="extras-col"><h3 style="font-family:\'Bebas Neue\',sans-serif;font-size:24px;color:var(--text);margin-bottom:12px;">Autor Gol <span style="color:#75AADB">Argentina</span></h3>'+argHtml+'</div>'+
    '<div class="extras-col"><h3 style="font-family:\'Bebas Neue\',sans-serif;font-size:24px;color:var(--gold);margin-bottom:12px;">Predicciones Generales</h3><div class="extras-grid">'+gridHtml+'</div></div>'+
  '</div>';
  loadInputValues();
}

function loadInputValues(){
  if(!currentUser)return;
  var ups=pronosticos[currentUser]||{};
  if(currentPhase==='extras'){
    var ext=ups.extras||{};
    EXTRAS_DATA.arg.concat(EXTRAS_DATA.grid).forEach(function(e){
      var el=document.getElementById(e.id);
      if(el&&ext[e.id]!==undefined)el.value=ext[e.id];
    });
    return;
  }
  Object.keys(ups).forEach(function(id){
    if(id==='extras')return;
    var hi=document.getElementById('h-'+id);
    var ai=document.getElementById('a-'+id);
    if(hi)hi.value=ups[id].h;
    if(ai)ai.value=ups[id].a;
  });
}

function markChanged(id){
  var c=document.getElementById('mc-'+id);
  if(c)c.style.borderColor='rgba(201,162,39,.4)';
}
function markExtraChanged(id){
  var b=document.getElementById('eb-'+id);
  if(b)b.style.borderColor='rgba(201,162,39,.4)';
}

// ══════════════════════════════════════════
//  SAVE PRONÓSTICOS
// ══════════════════════════════════════════
function savePronosticos(){
  if(!currentUser){showToast('⚠️ Primero ingresá al grupo');return;}
  if(!pronosticos[currentUser])pronosticos[currentUser]={};
  var count=0;

  if(currentPhase==='extras'){
    if(!pronosticos[currentUser].extras)pronosticos[currentUser].extras={};
    EXTRAS_DATA.arg.concat(EXTRAS_DATA.grid).forEach(function(e){
      var el=document.getElementById(e.id);
      if(el&&el.value.trim()!==''){
        pronosticos[currentUser].extras[e.id]=e.type==='number'?parseInt(el.value):el.value.trim();
        count++;
      }
    });
  } else {
    Object.keys(FIXTURE).forEach(function(phase){
      FIXTURE[phase].forEach(function(m){
        var hi=document.getElementById('h-'+m.id);
        var ai=document.getElementById('a-'+m.id);
        if(hi&&ai&&hi.value!==''&&ai.value!==''){
          pronosticos[currentUser][m.id]={h:parseInt(hi.value),a:parseInt(ai.value)};
          var card=document.getElementById('mc-'+m.id);
          if(card){card.classList.add('saved');card.style.borderColor='';}
          count++;
        }
      });
    });
  }

  localStorage.setItem('prodeData_'+currentUser,JSON.stringify(pronosticos[currentUser]));
  if(db){
    db.collection('pronosticos').doc(currentUser).set({
      nombre:currentUser,
      pronosticos:pronosticos[currentUser],
      updatedAt:new Date().toISOString()
    }).then(function(){
      showToast('✅ '+count+' datos guardados');
    }).catch(function(err){
      showToast('⚠️ Guardado local OK — Firebase: '+err.message);
    });
  } else {
    showToast('✅ '+count+' datos guardados (local)');
  }
  updateStats(); updateTabla(); updateMatchSelector();
}

